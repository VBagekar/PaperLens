# PaperLens — .gitignore

# OS files
.DS_Store
Thumbs.db
desktop.ini
__pycache__/
*.pyc
# Editor directories
.vscode/
.idea/
*.swp
*.swo

# Node (if you ever add a dev server or build step)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
dist/
build/

# Environment
.env
.env.local

# Logs
*.log
venv/
dataset/*.pkl
models/*.pkl
!outputs/